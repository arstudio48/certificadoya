{
  "version": 2,
  "rewrites": [
    { "source": "/panel-tecnicos", "destination": "/panel-tecnicos.html" },
    { "source": "/legal/:path*", "destination": "/legal/:path*" }
  ],
  "headers": [
    { "source": "/panel-tecnicos", "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }] },
    { "source": "/legal/(.*)", "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }] }
  ]
}
